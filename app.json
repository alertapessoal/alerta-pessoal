{
  "expo": {
    "name": "Alerta Pessoal",
    "slug": "alerta-pessoal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alertapessoal",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.alertapessoal.app",
      "icon": "./assets/images/icon.png",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#031B4E",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.alertapessoal.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#031B4E",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/alerta.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f2f12321-1b92-496d-8776-e6710675d0bb"
      }
    }
  }
}
